        "jsonBody": "={{ { \"contents\": [{ \"parts\": [{ \"text\": \"You are a technical recruiter. Analyze this CV:\\n\\n\" + $json.text + \"\\n\\nJob Description:\\nRole: Software Engineer Intern AI/ML\\nRequired: Python, FastAPI/Django, JavaScript, React, n8n, OpenAI API, Google Gemini API, Git\\nBonus: Twilio or telephony APIs\\n\\nReturn ONLY this exact JSON with no markdown:\\n{\\\"candidate_name\\\": \\\"name\\\", \\\"match_score\\\": 0-100, \\\"matched_skills\\\": [\\\"skill\\\"], \\\"missing_skills\\\": [\\\"skill\\\"], \\\"summary\\\": \\\"2 sentences\\\"}\" }] }] } }}",
        "options": {}
