    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const responseText = $input.item.json.candidates[0].content.parts[0].text;\nconst cleaned = responseText.replace(/```json|```/g, \"\").trim();\nconst parsed = JSON.parse(cleaned);\n\nreturn {\n  json: {\n    candidateName: parsed.candidate_name,\n    matchScore: parsed.match_score,\n    matchedSkills: parsed.matched_skills.join(\", \"),\n    missingSkills: parsed.missing_skills.join(\", \"),\n    summary: parsed.summary,\n    timestamp: new Date().toISOString()\n  }\n};"
      },
